# Environment Variables for Ay Amor Backend

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ay_amor"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
